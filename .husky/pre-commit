#!/bin/sh

# Get staged files
FILES=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$FILES" ] && exit 0

# Format ALL staged files (safe for spaces)
git diff --cached --name-only -z --diff-filter=ACMR \
  | xargs -0 pnpm exec prettier --write --ignore-unknown

# Lint only JS/TS files (safe for spaces + no-match)
git diff --cached --name-only -z --diff-filter=ACMR \
  | grep -zE '\.(js|ts|tsx)$' \
  | xargs -0 pnpm exec eslint --fix --max-warnings=100 || true

# Re-add ONLY staged files (not entire repo)
git diff --cached --name-only -z --diff-filter=ACMR \
  | xargs -0 git add